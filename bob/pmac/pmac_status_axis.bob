  <widget type="byte_monitor" version="2.0.0">
    <name>Status:Status3</name>
    <pv_name>$(pmac):AXIS$(axis):status3</pv_name>
    <x>15</x>
    <y>225</y>
    <width>20</width>
    <height>310</height>
    <numBits>16</numBits>
    <bitReverse>true</bitReverse>
    <horizontal>false</horizontal>
    <square>true</square>
    <off_color>
      <color name="Green LED: Off" red="0" green="96" blue="0">
      </color>
    </off_color>
    <on_color>
      <color name="Green LED: On" red="0" green="255" blue="0">
      </color>
    </on_color>
    <foreground_color>
      <color name="Black" red="0" green="0" blue="0">
      </color>
    </foreground_color>
    <actions>
    </actions>
    <rules>
      <rule name="onColorAlarm" prop_id="on_color" out_exp="false">
        <exp bool_exp="pvLegacySev0==-1">
          <value>
            <color name="Invalid" red="255" green="255" blue="255">
            </color>
          </value>
        </exp>
        <pv_name>$(pv_name)</pv_name>
      </rule>
      <rule name="offColorAlarm" prop_id="off_color" out_exp="false">
        <exp bool_exp="pvLegacySev0==-1">
          <value>
            <color name="Grey 25%" red="64" green="64" blue="64">
            </color>
          </value>
        </exp>
        <pv_name>$(pv_name)</pv_name>
      </rule>
    </rules>
    <border_alarm_sensitive>false</border_alarm_sensitive>
  </widget>

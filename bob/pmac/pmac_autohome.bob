      <rules>
        <rule name="onColorAlarm" prop_id="on_color" out_exp="false">
          <exp bool_exp="pvLegacySev0==-1">
            <value>
              <color name="Invalid" red="255" green="255" blue="255">
              </color>
            </value>
          </exp>
          <pv_name>$(pv_name)</pv_name>
        </rule>
        <rule name="offColorAlarm" prop_id="off_color" out_exp="false">
          <exp bool_exp="pvLegacySev0==-1">
            <value>
              <color name="Grey 25%" red="64" green="64" blue="64">
              </color>
            </value>
          </exp>
          <pv_name>$(pv_name)</pv_name>
        </rule>
      </rules>
      <border_alarm_sensitive>false</border_alarm_sensitive>
    </widget>
  </widget>
</display>

  <widget type="group" version="3.0.0">
    <name>General purpose outputs</name>
    <x>306</x>
    <y>658</y>
    <width>442</width>
    <height>80</height>
    <style use_class="true">0</style>
    <font use_class="true">
      <font family="Arial" style="REGULAR" size="15.0">
      </font>
    </font>
    <foreground_color use_class="true">
      <color red="29" green="41" blue="69">
      </color>
    </foreground_color>
    <background_color use_class="true">
      <color name="Read_Background" red="240" green="240" blue="240">
      </color>
    </background_color>
    <transparent>true</transparent>
    <actions>
    </actions>
    <widget type="byte_monitor" version="2.0.0">
      <name>EDM Byte_4</name>
      <pv_name>$(pmac):GPIO_OP_BITS</pv_name>
      <y>14</y>
      <width>400</width>
      <height>22</height>
      <numBits>16</numBits>
      <bitReverse>true</bitReverse>
      <square>true</square>
      <off_color use_class="true">
        <color red="237" green="237" blue="237">
        </color>
      </off_color>
      <on_color use_class="true">
        <color name="Write_Background" red="128" green="255" blue="255">
        </color>
      </on_color>
      <foreground_color use_class="true">
        <color name="Text" red="0" green="0" blue="0">
        </color>
      </foreground_color>
      <font use_class="true">
        <font name="Default" family="Liberation Sans" style="REGULAR" size="14.0">
        </font>
      </font>
      <actions>
      </actions>
      <rules>
        <rule name="onColorAlarm" prop_id="on_color" out_exp="false">
          <exp bool_exp="pvLegacySev0==-1">
            <value>
              <color name="Invalid" red="255" green="255" blue="255">
              </color>
            </value>
          </exp>
          <exp bool_exp="pvLegacySev0==1">
            <value>
              <color name="Major" red="255" green="0" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pvLegacySev0==2">
            <value>
              <color name="Minor" red="255" green="241" blue="0">
              </color>
            </value>

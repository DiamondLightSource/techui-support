    <widget type="byte_monitor" version="2.0.0">
      <name>EDM Byte</name>
      <pv_name>$(pmac):CTRLSTAT:status1</pv_name>
      <width>11</width>
      <height>194</height>
      <numBits>16</numBits>
      <horizontal>false</horizontal>
      <square>true</square>
      <off_color>
        <color name="Green LED: Off" red="0" green="96" blue="0">
        </color>
      </off_color>
      <on_color>
        <color name="Green LED: On" red="0" green="255" blue="0">
        </color>
      </on_color>
      <foreground_color>
        <color red="192" green="192" blue="192">
        </color>
      </foreground_color>
      <actions>
      </actions>
      <rules>
        <rule name="onColorAlarm" prop_id="on_color" out_exp="false">
          <exp bool_exp="pvLegacySev0==-1">
            <value>
              <color name="Invalid" red="255" green="255" blue="255">
              </color>
            </value>
          </exp>
          <exp bool_exp="pvLegacySev0==1">
            <value>
              <color name="Major" red="255" green="0" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pvLegacySev0==2">
            <value>
              <color name="Minor" red="255" green="241" blue="0">
              </color>
            </value>
          </exp>
          <pv_name>$(pmac):CTRLSTAT:status1</pv_name>
        </rule>
      </rules>
      <border_alarm_sensitive>false</border_alarm_sensitive>
    </widget>

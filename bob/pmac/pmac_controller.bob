      <widget type="byte_monitor" version="2.0.0">
        <name>EDM Byte</name>
        <pv_name>$(pmac):CTRLSTAT:status3</pv_name>
        <width>11</width>
        <height>194</height>
        <numBits>16</numBits>
        <horizontal>false</horizontal>
        <square>true</square>
        <off_color use_class="true">
          <color red="237" green="237" blue="237">
          </color>
        </off_color>
        <on_color use_class="true">
          <color name="Write_Background" red="128" green="255" blue="255">
          </color>
        </on_color>
        <foreground_color use_class="true">
          <color name="Text" red="0" green="0" blue="0">
          </color>
        </foreground_color>
        <font use_class="true">
          <font name="Default" family="Liberation Sans" style="REGULAR" size="14.0">
          </font>
        </font>
        <actions>
        </actions>
        <rules>
          <rule name="onColorAlarm" prop_id="on_color" out_exp="false">
            <exp bool_exp="pvLegacySev0==-1">
              <value>
                <color name="Invalid" red="255" green="255" blue="255">
                </color>
              </value>
            </exp>
            <exp bool_exp="pvLegacySev0==1">
              <value>
                <color name="Major" red="255" green="0" blue="0">
                </color>
              </value>
            </exp>
            <exp bool_exp="pvLegacySev0==2">
              <value>
                <color name="Minor" red="255" green="241" blue="0">
                </color>
              </value>
            </exp>
            <pv_name>$(pmac):CTRLSTAT:status3</pv_name>
          </rule>
        </rules>
        <border_alarm_sensitive>false</border_alarm_sensitive>
      </widget>
    </widget>
